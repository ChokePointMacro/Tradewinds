# ─── Tradewinds environment (PRD Section 8) ────────────────────────────────────
# Rule: any var WITHOUT the VITE_ prefix is server-only and must NEVER be
# imported into client code. CI (scripts/check-secrets.mjs) fails the build if a
# server-only secret leaks into the client bundle.

# Data mode: mock | live
# `live` routes prices through /api/price/* behind the `live-prices` PostHog flag;
# it falls back to mock on any error. The default provider (yahoo) is KEYLESS, so
# live prices work with just this set to `live` — no PRICE_API_KEY required.
VITE_DATA_MODE=mock

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, never exposed to client

# Price provider (server-only) — consumed by /api/price/* serverless functions.
# `yahoo` (default) is keyless. The others quote via a rates map and need a key.
PRICE_API_PROVIDER=yahoo               # yahoo | commoditypriceapi | metalpriceapi | oilpriceapi | apininjas
PRICE_API_KEY=                          # server-only; not needed for yahoo

# UN Comtrade (server-only) — consumed by /api/comtrade/* serverless functions.
# Upgrades the Route Map "Net trade" overlay from MODELED seed to SOURCED
# (per-country net trade in USD bn/yr) behind the `live-trade` PostHog flag.
# Get a FREE key at https://comtradeplus.un.org (Account → API Keys); free tier
# is 500 calls/day. Without this key the overlay gracefully stays on MODELED seed.
COMTRADE_API_KEY=                       # server-only; never VITE_-prefixed

# Map tiles (free default needs none; set if upgrading)
VITE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# Analytics
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Auth (Phase 2 — multi-tenant; leave blank for MVP)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
